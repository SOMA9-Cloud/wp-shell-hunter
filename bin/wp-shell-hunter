#!/usr/bin/env python3
"""wp-shell-hunter launcher.

Adds the bundled src/ directory to sys.path so the tool runs without
pip-install. Useful for curl-pipe-bash deployment scenarios.
"""
import os
import sys

_HERE = os.path.dirname(os.path.realpath(__file__))
_SRC = os.path.join(os.path.dirname(_HERE), "src")
if os.path.isdir(_SRC):
    sys.path.insert(0, _SRC)

from wp_shell_hunter.__main__ import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
